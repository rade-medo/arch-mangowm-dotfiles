/* Rofi config — ~/.config/rofi/config.rasi */

configuration {
  modi:                   "drun,run,window";
  show-icons:             true;
  terminal:               "kitty";
  drun-display-format:    "{name}";
  window-format:          "{w} · {c} · {t}";
  icon-theme:             "Papirus-Dark";
  display-drun:           " Apps";
  display-run:            " Run";
  display-window:         "ﱭ Windows";
}

@theme "gruvbox-dark-hard"
